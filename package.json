{
  "name": "production-template",
  "version": "0.1.0",
  "private": true,
  "description": "A production-ready React + Express monorepo with Clerk auth, Prisma ORM, and comprehensive testing.",
  "keywords": [
    "react",
    "express",
    "prisma",
    "clerk",
    "typescript",
    "monorepo",
    "template"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:client": "pnpm --filter @repo/client dev",
    "dev:server": "pnpm --filter @repo/server dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test -- --coverage",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @repo/server db:generate",
    "db:push": "pnpm --filter @repo/server db:push",
    "db:migrate": "pnpm --filter @repo/server db:migrate",
    "db:migrate:deploy": "pnpm --filter @repo/server db:migrate:deploy",
    "db:rollback": "pnpm --filter @repo/server db:rollback",
    "db:studio": "pnpm --filter @repo/server db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.49.0",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
